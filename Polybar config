[colors]
# Everforest-inspired palette
background = #1d1f21
background-alt = #282a2e
foreground = #c5c8c6
primary = #969896
disabled = #4d4d4d
alert = #a54242

[bar/top]
width = 100%
height = 18pt
radius = 0
background = ${colors.background}
foreground = ${colors.foreground}

line-size = 2pt
padding-left = 1
padding-right = 1
module-margin = 1
separator = |
separator-foreground = ${colors.disabled}

# Fonts (Make sure to have Font Awesome installed)
font-0 = "monospace:size=10;2"
font-1 = "Font Awesome 6 Free Solid:size=10;2"

# Module placement
modules-left = xworkspaces
modules-center = date
modules-right = wlan pulseaudio memory cpu

cursor-click = pointer
enable-ipc = true

[module/xworkspaces]
type = internal/xworkspaces
label-active = %name%
label-active-background = ${colors.background-alt}
label-active-underline = ${colors.primary}
label-active-padding = 1

label-occupied = %name%
label-occupied-padding = 1

label-urgent = %name%
label-urgent-background = ${colors.alert}
label-urgent-padding = 1

label-empty = %name%
label-empty-foreground = ${colors.disabled}
label-empty-padding = 1

[module/pulseaudio]
type = internal/pulseaudio
# Volume control using scroll wheel
scroll-up = pactl set-sink-volume @DEFAULT_SINK@ +5%
scroll-down = pactl set-sink-volume @DEFAULT_SINK@ -5%
# Right click opens pavucontrol
click-right = pavucontrol

format-volume = <label-volume>
label-volume = VOL %percentage%%
label-muted = VOL MUTED
label-muted-foreground = ${colors.disabled}

[module/wlan]
type = internal/network
# Change 'wlp1s0' to your network interface name
interface = wlp1s0
interval = 3.0

format-connected = <label-connected>
label-connected = %{A3:nm-connection-editor &:}%{A}
label-connected-foreground = ${colors.primary}

format-disconnected = <label-disconnected>
label-disconnected = %{A3:nm-connection-editor &:}%{A}
label-disconnected-foreground = ${colors.disabled}

[module/memory]
type = internal/memory
interval = 2
label = RAM %percentage_used%%

[module/cpu]
type = internal/cpu
interval = 2
label = CPU %percentage%%

[module/date]
type = internal/date
interval = 1
date = %H:%M
label = %date%

[settings]
screenchange-reload = true
pseudo-transparency = true
